# 启航平台 - 环境变量配置示例
# 复制本文件为 .env，填入真实配置

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的MySQL密码
DB_NAME=qihang_platform

# JWT 密钥（必填！请替换为随机长字符串）
# 生成方法: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ⚠️ 警告：使用默认值或弱密钥将导致严重安全漏洞
JWT_SECRET=请替换为随机密钥
JWT_REFRESH_SECRET=请替换为另一个随机密钥
JWT_EXPIRES_IN=7d

# 服务端口
PORT=3001
NODE_ENV=development

# CORS 白名单（生产环境配置具体域名）
CORS_ORIGIN=http://localhost:5173

# 文件上传配置
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE=5242880    # 5MB
MAX_DOC_SIZE=10485760     # 10MB

# 数据加密密钥（64位十六进制，生产环境必填）
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
